# BadZure Environment Variables
# Copy this file to .env and fill in your values
# The .env file is already in .gitignore and won't be committed

# Azure Tenant ID (GUID)
BADZURE_TENANT_ID=your-tenant-id-here

# Azure AD Domain (e.g., yourtenant.onmicrosoft.com)
BADZURE_DOMAIN=yourtenant.onmicrosoft.com

# Azure Subscription ID (GUID)
BADZURE_SUBSCRIPTION_ID=your-subscription-id-here
